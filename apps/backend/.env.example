# Indom Backend Environment Variables
# Copy this file to `.env` and fill in your API keys for the cloud providers.

# 1. OpenRouter (model type: "openrouter")
OPENROUTER_API_KEY="sk-or-v1-..."

# 2. OpenAI (model type: "openai")
OPENAI_API_KEY="sk-proj-..."

# 3. Anthropic (model type: "anthropic")
ANTHROPIC_API_KEY="sk-ant-..."

# 4. Google Gemini (model type: "gemini")
GEMINI_API_KEY="AIzaSy..."

# 5. DeepSeek (model type: "deepseek")
DEEPSEEK_API_KEY="sk-..."
